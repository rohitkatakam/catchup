# --- MVP checklist (manual flow before automated cron) ---
# 1. Same Upstash Redis for local dev and prod if you test end-to-end on a deployment.
# 2. DISPATCH_APP_URL must be the URL people open to submit (e.g. https://your-app.vercel.app).
#    Do not use localhost in that variable for real audience emails.
# 3. CRON_SECRET authorizes GET /api/cron/prompt and GET /api/cron/generate (Bearer or x-cron-secret).
# 4. Fill Resend + AI gateway below, then run: npm run mvp:triggers (after setting BASE_URL + CRON_SECRET)

# Upstash Redis
UPSTASH_REDIS_REST_URL="https://your-upstash-endpoint.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Resend
RESEND_API_KEY="re_your_resend_api_key"
DISPATCH_FROM_EMAIL="dispatch@your-domain.com"
DISPATCH_AUDIENCE_ID="your_resend_audience_id"
# Public URL of the submission form (linked from prompt broadcasts)
DISPATCH_APP_URL="https://your-deployment.vercel.app"

# Vercel AI Gateway (used with DISPATCH_MODEL for LLM synthesis)
AI_GATEWAY_API_KEY="your_vercel_ai_gateway_key"
DISPATCH_MODEL="openai/gpt-4o-mini"

# AI + tracing (Respan)
RESPAN_API_KEY="your-respan-api-key"
RESPAN_PROJECT_ID="your-respan-project-id"

# Shared secret for manual/cron-style GET triggers (prompt + generate)
CRON_SECRET="your-random-cron-secret"
